--- a/libavformat/fafrdec.c
+++ b/libavformat/fafrdec.c
@@ -0,0 +1,170 @@
+/*
+ * FAFR demuxer
+ *
+ * This file is part of FFmpeg.
+ *
+ * FFmpeg is free software; you can redistribute it and/or
+ * modify it under the terms of the GNU Lesser General Public
+ * License as published by the Free Software Foundation; either
+ * version 2.1 of the License, or (at your option) any later version.
+ */
+
+#include <stdint.h>
+
+#include "config_components.h"
+#include "libavutil/channel_layout.h"
+#include "libavutil/intreadwrite.h"
+#include "libavutil/mem.h"
+#include "avformat.h"
+#include "demux.h"
+#include "internal.h"
+
+#define FAFR_MAGIC 0x52464146u
+#define FAFR_VERSION 1u
+#define FAFR_DTYPE_COMPLEX_F32 1u
+#define FAFR_HEADER_SIZE 40
+
+typedef struct FafrDemuxContext {
+    int frame_size;
+    int hop_size;
+    int channels;
+    int bins;
+    int frame_bytes;
+    uint64_t total_frames;
+    int64_t total_samples;
+    int64_t data_offset;
+    uint64_t frame_index;
+} FafrDemuxContext;
+
+static int fafr_probe(const AVProbeData *p)
+{
+    if (p->buf_size < 4)
+        return 0;
+    if (AV_RL32(p->buf) == FAFR_MAGIC)
+        return AVPROBE_SCORE_MAX;
+    return 0;
+}
+
+static int fafr_read_header(AVFormatContext *s)
+{
+    FafrDemuxContext *ctx = s->priv_data;
+    AVIOContext *pb = s->pb;
+    AVStream *st;
+    uint8_t hdr[FAFR_HEADER_SIZE];
+    uint32_t magic, version, sample_rate, dtype;
+    uint32_t frame_size, hop_size;
+    uint16_t channels;
+    uint64_t total_frames, total_samples;
+
+    if (avio_read(pb, hdr, FAFR_HEADER_SIZE) < FAFR_HEADER_SIZE)
+        return AVERROR_INVALIDDATA;
+
+    magic = AV_RL32(hdr + 0);
+    version = AV_RL32(hdr + 4);
+    sample_rate = AV_RL32(hdr + 8);
+    channels = AV_RL16(hdr + 12);
+    dtype = AV_RL16(hdr + 14);
+    frame_size = AV_RL32(hdr + 16);
+    hop_size = AV_RL32(hdr + 20);
+    total_samples = AV_RL64(hdr + 24);
+    total_frames = AV_RL64(hdr + 32);
+
+    if (magic != FAFR_MAGIC || version != FAFR_VERSION || dtype != FAFR_DTYPE_COMPLEX_F32)
+        return AVERROR_INVALIDDATA;
+    if (!frame_size || !hop_size || hop_size > frame_size || !channels)
+        return AVERROR_INVALIDDATA;
+
+    ctx->frame_size = (int)frame_size;
+    ctx->hop_size = (int)hop_size;
+    ctx->channels = (int)channels;
+    ctx->bins = ctx->frame_size / 2 + 1;
+    ctx->frame_bytes = ctx->bins * ctx->channels * 2 * (int)sizeof(float);
+    ctx->total_frames = total_frames;
+    ctx->total_samples = (int64_t)total_samples;
+    ctx->data_offset = avio_tell(pb);
+    ctx->frame_index = 0;
+
+    st = avformat_new_stream(s, NULL);
+    if (!st)
+        return AVERROR(ENOMEM);
+
+    st->codecpar->codec_type = AVMEDIA_TYPE_AUDIO;
+    st->codecpar->codec_id = AV_CODEC_ID_FAFR;
+    st->codecpar->sample_rate = (int)sample_rate;
+    av_channel_layout_default(&st->codecpar->ch_layout, ctx->channels);
+    st->codecpar->block_align = ctx->frame_bytes;
+
+    st->duration = ctx->total_samples;
+    avpriv_set_pts_info(st, 64, 1, sample_rate);
+
+    st->codecpar->extradata = av_mallocz(FAFR_HEADER_SIZE + AV_INPUT_BUFFER_PADDING_SIZE);
+    if (!st->codecpar->extradata)
+        return AVERROR(ENOMEM);
+    memcpy(st->codecpar->extradata, hdr, FAFR_HEADER_SIZE);
+    st->codecpar->extradata_size = FAFR_HEADER_SIZE;
+
+    return 0;
+}
+
+static int fafr_read_packet(AVFormatContext *s, AVPacket *pkt)
+{
+    FafrDemuxContext *ctx = s->priv_data;
+    int ret;
+
+    if (ctx->total_frames && ctx->frame_index >= ctx->total_frames)
+        return AVERROR_EOF;
+
+    ret = av_new_packet(pkt, ctx->frame_bytes);
+    if (ret < 0)
+        return ret;
+
+    ret = avio_read(s->pb, pkt->data, ctx->frame_bytes);
+    if (ret < ctx->frame_bytes) {
+        av_packet_unref(pkt);
+        return AVERROR_EOF;
+    }
+
+    pkt->stream_index = 0;
+    pkt->pts = ctx->frame_index * (int64_t)ctx->hop_size;
+    pkt->duration = ctx->hop_size;
+    ctx->frame_index++;
+    return ctx->frame_bytes;
+}
+
+static int fafr_read_seek(AVFormatContext *s, int stream_index, int64_t timestamp, int flags)
+{
+    FafrDemuxContext *ctx = s->priv_data;
+    int64_t frame;
+    int64_t pos;
+
+    (void)flags;
+    (void)stream_index;
+
+    if (ctx->hop_size <= 0)
+        return AVERROR(EINVAL);
+
+    frame = timestamp / ctx->hop_size;
+    if (frame < 0)
+        frame = 0;
+    if (ctx->total_frames && frame >= (int64_t)ctx->total_frames)
+        frame = (int64_t)ctx->total_frames - 1;
+
+    pos = ctx->data_offset + frame * (int64_t)ctx->frame_bytes;
+    if (avio_seek(s->pb, pos, SEEK_SET) < 0)
+        return AVERROR(EIO);
+
+    ctx->frame_index = frame;
+    return 0;
+}
+
+const FFInputFormat ff_fafr_demuxer = {
+    .p.name         = "fafr",
+    .p.long_name    = NULL_IF_CONFIG_SMALL("FAFR (Framewise Audio Fourier Representation)"),
+    .p.extensions   = "fafr",
+    .p.flags        = AVFMT_GENERIC_INDEX,
+    .priv_data_size = sizeof(FafrDemuxContext),
+    .read_probe     = fafr_probe,
+    .read_header    = fafr_read_header,
+    .read_packet    = fafr_read_packet,
+    .read_seek      = fafr_read_seek,
+};
